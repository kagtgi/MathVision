{
  "name": "math-vision",
  "private": true,
  "version": "1.0.0",
  "description": "An expert AI assistant for mathematics teachers — converts handwritten or printed math content from images into clean, ready-to-use LaTeX and TikZ code.",
  "author": "MathVision Team",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit",
    "electron:preview": "npm run build && electron .",
    "electron:build": "node scripts/fix-electron-cache.cjs && npm run build && electron-builder --win"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "docx": "^9.6.1",
    "framer-motion": "^12.38.0",
    "katex": "^0.16.39",
    "lucide-react": "^0.546.0",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "ai.tasih.mathvision",
    "productName": "MathVision",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs"
    ],
    "win": {
      "target": [
        { "target": "zip", "arch": ["x64"] }
      ]
    }
  }
}
